# Variáveis de ambiente do backend VilaReal (produção na VPS)
#
# ONDE COLOCAR OS VALORES REAIS (não commitar):
#   /opt/villareal/villareal/.env.docker
#
# Deploy padrão (do Mac):
#   ssh root@161.97.175.73 "cd /opt/villareal/villareal && git pull origin main && \
#     docker compose --env-file .env.docker build && \
#     docker compose --env-file .env.docker up -d"
#
# O docker-compose.yml repassa ${NOME} ao container via bloco environment: — requer
# sempre: docker compose --env-file .env.docker ...

# --- Perfil Spring ---
SPRING_PROFILES_ACTIVE=prod

# --- MySQL (systemd na VPS; container acessa host.docker.internal:3306) ---
VILLAREAL_COMPOSE_JDBC_URL=jdbc:mysql://host.docker.internal:3306/vilareal?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=UTC
VILLAREAL_COMPOSE_JDBC_USER=root
VILLAREAL_COMPOSE_JDBC_PASSWORD=

# --- Google Drive (Shared Drive primário — cota da organização) ---
# Villa Real Documentos. SA membro do drive; não exige impersonação.
GOOGLE_DRIVE_SHARED_DRIVE_ID=0ANU_zUd2tFQ7Uk9PVA
# Fallback opcional (só se shared-drive-id vazio): domain-wide delegation
GOOGLE_DRIVE_IMPERSONATE_USER=

# --- PROJUDI (cofre de credenciais) ---
# Chave AES-256 em Base64 (32 bytes). Deve ser a MESMA usada ao cadastrar a senha PROJUDI.
PROJUDI_CRED_KEY=
PROJUDI_ORQUESTRADOR_CREDENCIAL_ID=1

# --- Movimentações Email (loop Gmail + fila Drive; desliga scheduler PROJUDI de 3h) ---
VILAREAL_EMAIL_PROJUDI_PIPELINE_ENABLED=true

# --- PJe TRT18 (cópia integral via Playwright + Tailscale SOCKS5) ---
# PJe bloqueia IP de datacenter — proxy residencial obrigatório.
# tailscale status na VPS → use IP 100.x.x.x da máquina com SOCKS5 na porta 1080.
PJE_BROWSER_ENABLED=true
PJE_BROWSER_PROXY=socks5://100.123.21.81:1080
PJE_TRT18_LOGIN_PADRAO=00733235190
PJE_EMAIL_TRIGGER_ENABLED=true

# --- DataJud / CNJ (sincronização de órgãos julgadores) ---
# Chave da API pública do DataJud. Base URL tem default no compose; sobrescreva só se necessário.
DATAJUD_API_KEY=
# DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=

# --- JWT (produção — mínimo 32 caracteres) ---
JWT_SECRET=

# --- WhatsApp (ver WHATSAPP_SETUP.md na raiz) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VALIDATE_SIGNATURE=true

# --- Arquivos na VPS (fora deste .env) ---
# google-drive-credentials.json → e-vilareal-java-backend/src/main/resources/ (build context Docker)
# credentials.json (Gmail OAuth) → idem
# /home/vilareal/gmail-tokens → volume montado no compose

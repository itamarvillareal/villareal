# Template da instância portal1 (não versionar o arquivo real `.env.portal1`).
# Na VPS: /opt/villareal/villareal/.env.portal1
#
# Uso:
#   docker compose -p portal1 --env-file .env.portal1 up -d

# --- Identidade da instância ---
COMPOSE_CONTAINER_PREFIX=portal1
HOST_BACKEND_PORT=8082
HOST_FRONTEND_PORT=5174
INSTANCE_DATA_ROOT=/home/vilareal/portal1

SPRING_PROFILES_ACTIVE=prod

# --- MySQL (mesmo servidor; schema isolado) ---
VILLAREAL_COMPOSE_JDBC_URL=jdbc:mysql://host.docker.internal:3306/vilareal_portal1?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=utf8&serverTimezone=UTC
VILLAREAL_COMPOSE_JDBC_USER=root
VILLAREAL_COMPOSE_JDBC_PASSWORD=

# --- Secrets próprios da instância (não reutilizar os do portal) ---
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
ASSINADOR_API_SECRET=
ASSINADOR_REQUIRE_HTTPS=true

# --- IA / DataJud (podem ser as mesmas chaves de plataforma) ---
ANTHROPIC_API_KEY=
DATAJUD_API_KEY=
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# --- Google Drive (obrigatório em prod para o backend subir) ---
# Mesmo Shared Drive "Villa Real Documentos", mas raiz = pasta "Sistema"
# (irmã de "Sistema VilaReal" do portal). Subpastas: clientes/01 - Ativos, Pessoas, Imóveis.
GOOGLE_DRIVE_SHARED_DRIVE_ID=0ANU_zUd2tFQ7Uk9PVA
GOOGLE_DRIVE_ROOT_FOLDER_ID=1L-Toddl68HqBnb7-eF3TD3-hobzBokwV
GOOGLE_DRIVE_IMPERSONATE_USER=

# --- Demais integrações do escritório: desligadas no dia 1 ---
PROJUDI_CRED_KEY=
PROJUDI_ORQUESTRADOR_CREDENCIAL_ID=1
VILAREAL_EMAIL_PROJUDI_PIPELINE_ENABLED=false

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VALIDATE_SIGNATURE=false

CORA_ENABLED=false

PJE_BROWSER_ENABLED=false
PJE_BROWSER_HEADLESS=true
PJE_BROWSER_PROXY=
PJE_EMAIL_TRIGGER_ENABLED=false
PJE_COPIA_INTEGRAL_DOWNLOAD_TIMEOUT_MS=900000

# Copie para import-pessoas.local.env e ajuste o caminho da planilha.
# Uso: ./scripts/run-import-pessoas.sh
#
# Planilha oficial (Dropbox):
VILAREAL_IMPORT_PESSOAS_PATH="/Users/itamar/Dropbox/Sistema/Cadastro Pessoas - Itamar.xls"

# Carga real (false) vs simulação (true)
VILAREAL_IMPORT_PESSOAS_DRY_RUN=false

# 0 = todas as linhas com ID válido
VILAREAL_IMPORT_PESSOAS_LIMIT=0

# Atualizar registos existentes e reconciliar por CPF quando o id da planilha não existir
VILAREAL_IMPORT_PESSOAS_UPDATE_EXISTING=true
VILAREAL_IMPORT_PESSOAS_RECONCILE_BY_CPF_WHEN_ID_MISSING=true

# Relatório CSV (relativo à pasta do backend se não for absoluto)
VILAREAL_IMPORT_PESSOAS_REPORT_PATH=import-pessoas-report.csv

# true = job one-shot via Docker (MySQL vilareal-db em localhost:3307)
VILAREAL_IMPORT_PESSOAS_DOCKER=true

# Snapshot para comparar alterações entre importações (gerido por run-import-pessoas.sh)
# VILAREAL_IMPORT_PESSOAS_SNAPSHOT_PATH=scripts/import-pessoas-last-snapshot.json

# Copie este ficheiro para import-pessoas.local.env (o nome exacto é importante).
#   cp scripts/import-pessoas.local.env.example scripts/import-pessoas.local.env
# O ficheiro import-pessoas.local.env está no .gitignore — não vai para o Git.

# Caminho fixo da sua planilha (actualize quando mudar de pasta ou nome do ficheiro)
export PLANILHA="$HOME/Downloads/Cadastro Pessoas - Itamar (1).xls"

# Valores por omissão em cada execução (pode sobrescrever na linha de comando: DRY_RUN=false LIMIT=0 ./scripts/run-import-pessoas.sh)
export DRY_RUN=true
export LIMIT=50

# Opcional: relatório CSV num sítio fixo
# export VILAREAL_IMPORT_PESSOAS_REPORT_PATH="$HOME/Desktop/import-pessoas-relatorio.csv"

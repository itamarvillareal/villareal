# PostgreSQL com extensão pgvector (ver docker-compose.rag-pgvector.yml)
DATABASE_URL=postgresql://rag:rag@localhost:5433/processo_rag

# MySQL operacional — fonte ÚNICA da verdade de prazos e valores
# (docker-compose.local-db.yml → localhost:3307)
MYSQL_URL=mysql://root:root@localhost:3307/vilareal

VOYAGE_API_KEY=
ANTHROPIC_API_KEY=

# Padrão para o dia a dia (alinhado ao backend Java). Para análise crítica de
# sentença/contestação, sobreponha pontualmente com --modelo claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Timeout (segundos) das queries ao MySQL operacional em perguntar() — falhar alto
# se o vilareal-db não responder a tempo (evita pendurar o fluxo em horário comercial).
MYSQL_QUERY_TIMEOUT_S=5

# Copie para import-from-mac.local.env (está no .gitignore).
#   cp scripts/import-from-mac.local.env.example scripts/import-from-mac.local.env
#
# Este servidor deve conseguir SSH ao Mac (mesma rede, IP público, Tailscale, etc.)
# e no Mac: Preferências → Partilhar → Acesso remoto / ssh activo.

export MAC_SSH_USER="itamar"
export MAC_SSH_HOST="192.168.1.100"

# Caminho absoluto da planilha NO MAC (tal como aparece no Finder)
export MAC_XLS_REMOTE="/Users/itamar/Dropbox/sistema/Cadastro Pessoas - Itamar.xls"

# Opcional: JAR da API em produção (se não for o padrão do run-import-pessoas.sh)
# export VILAREAL_IMPORT_PESSOAS_API_JAR="/opt/villareal/app/api.jar"

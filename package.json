{
  "name": "villareal-repo",
  "private": true,
  "description": "Atalhos npm na raiz — a app web vive em e-vilareal-react-web/",
  "scripts": {
    "import:debitos-calculos": "npm run import:debitos-calculos --prefix e-vilareal-react-web",
    "import:debitos-calculos:devtools": "npm run import:debitos-calculos:devtools --prefix e-vilareal-react-web",
    "dev:web": "npm run dev --prefix e-vilareal-react-web",
    "local-helper": "npm run start --prefix e-vilareal-local-helper",
    "local-helper:install": "npm run install:launchagent --prefix e-vilareal-local-helper",
    "local-helper:uninstall": "npm run uninstall:launchagent --prefix e-vilareal-local-helper",
    "local-helper:build-instalador": "npm run build:instalador-local-helper --prefix e-vilareal-react-web",
    "import:historico": "npm run import:historico --prefix e-vilareal-react-web",
    "dedupe:andamentos-processo": "npm run dedupe:andamentos-processo --prefix e-vilareal-react-web",
    "import:extrato-bancos-itau": "npm run import:extrato-bancos-itau --prefix e-vilareal-react-web",
    "import:extrato-bancos-itau:faltantes": "npm run import:extrato-bancos-itau:faltantes --prefix e-vilareal-react-web"
  }
}

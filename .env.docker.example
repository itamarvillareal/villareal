# Copiar para `.env.docker` na raiz (não versionado; ver `.gitignore`).
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  CENÁRIO 1 — Na VPS (produção / Docker apontando para MySQL local) │
# └─────────────────────────────────────────────────────────────────────┘
# O MySQL roda como serviço systemd na VPS. Os containers Docker
# acessam via host.docker.internal:3306.
#
# VILLAREAL_COMPOSE_JDBC_PASSWORD=root
# VILLAREAL_COMPOSE_JDBC_URL=jdbc:mysql://host.docker.internal:3306/vilareal?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=utf8&serverTimezone=UTC
# VILLAREAL_COMPOSE_JDBC_USER=root
#
# Profile Spring em produção (ajustar no compose ou override na VPS):
# SPRING_PROFILES_ACTIVE=prod
#
# =============================================
# Google Drive + PROJUDI (produção na VPS — valores reais só em `.env.docker`, gitignored)
# Template completo: deploy/backend.env.example
# =============================================
# Shared Drive primário (cota da org; SA membro — não precisa impersonação)
GOOGLE_DRIVE_SHARED_DRIVE_ID=0ANU_zUd2tFQ7Uk9PVA
# Fallback opcional (só se shared-drive-id vazio): domain-wide delegation
GOOGLE_DRIVE_IMPERSONATE_USER=
# Chave AES-256 Base64 (32 bytes) — estável entre restarts
PROJUDI_CRED_KEY=
#
# =============================================
# WhatsApp Cloud API (Meta) — Graph API v25.0
# Docs: ver WHATSAPP_SETUP.md
# =============================================
# Phone Number ID — obtido em: Meta Developers > App > WhatsApp > API Setup
# Produção: 1144756872051746 (+55 62 9404-5077 — Villa Real Advocacia)
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# Token permanente — obtido via: Business Manager > Usuários do Sistema > Gerar Token
# Permissões: whatsapp_business_management + whatsapp_business_messaging
# NUNCA commitar o token real. Gerar novo se comprometido.
WHATSAPP_ACCESS_TOKEN=seu_token_permanente

# Verify Token — string definida por você para validação do webhook
WHATSAPP_VERIFY_TOKEN=sua_string_secreta_webhook

# WABA ID — obtido em: Business Manager > Contas do WhatsApp
# Produção: 1272311911765478 (Villa Real Advocacia)
WHATSAPP_WABA_ID=seu_waba_id

# App Secret — obtido em: Meta Developers > App > Configurações > Básico
WHATSAPP_APP_SECRET=seu_app_secret

# Validação HMAC do webhook (true em produção, false em dev)
WHATSAPP_VALIDATE_SIGNATURE=true
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  CENÁRIO 2 — Dev local (túnel SSH para o MySQL da VPS)             │
# └─────────────────────────────────────────────────────────────────────┘
# Abra o túnel: ssh -L 3308:localhost:3306 root@161.97.175.73
# Depois use:
#
# VILLAREAL_COMPOSE_JDBC_PASSWORD=root
# VILLAREAL_COMPOSE_JDBC_URL=jdbc:mysql://host.docker.internal:3308/vilareal?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=utf8&serverTimezone=UTC
# VILLAREAL_COMPOSE_JDBC_USER=root
#
# Dev local — assinatura HMAC do webhook desligada (Meta em sandbox):
# WHATSAPP_VALIDATE_SIGNATURE=false

# =============================================
# Cora — Integração Direta (mTLS)
# Certificados no volume /home/vilareal/cora-certs/ (montado no container backend).
# NUNCA commitar certificate.pem nem private-key.pem.
# =============================================
# CORA_ENABLED=false
# CORA_CLIENT_ID=seu-client-id
# CORA_CERT_PATH=/home/vilareal/cora-certs/certificate.pem
# CORA_KEY_PATH=/home/vilareal/cora-certs/private-key.pem
# CORA_BASE_URL=https://matls-clients.api.stage.cora.com.br

VILLAREAL_COMPOSE_JDBC_PASSWORD=

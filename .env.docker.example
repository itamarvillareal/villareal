# Copiar para `.env.docker` na raiz (não versionado; ver `.gitignore`).
#
# FONTE DE VERDADE: o MySQL na VPS. Não dependas de um banco "só local" para dados de negócio.
# O stack Docker (dev-up.sh) lê/ grava no mesmo MySQL do portal, via túnel SSH (3308).
#
# Usado pelo `docker compose` (scripts/dev-up.sh) — JDBC do backend → host.docker.internal:3308 → VPS.

VILLAREAL_COMPOSE_JDBC_PASSWORD=

# Opcional (omitir para usar os defaults abaixo no docker-compose.yml):
# VILLAREAL_COMPOSE_JDBC_URL=jdbc:mysql://host.docker.internal:3308/vilareal?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=utf8&serverTimezone=UTC
# VILLAREAL_COMPOSE_JDBC_USER=villareal_remote
